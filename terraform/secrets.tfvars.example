# ============================================================================
# Penumbra — secret values for Terraform
# ============================================================================
# 1. Copy this file:    cp secrets.tfvars.example secrets.tfvars
# 2. Fill in values
# 3. Apply:             terraform apply -var-file=secrets.tfvars
#
# secrets.tfvars is gitignored — never commit it.
# ============================================================================

# GitHub repository in owner/name format (not sensitive — can go in terraform.tfvars)
github_repo = "YOUR_GITHUB_USERNAME/penumbra"

# Polymarket L2 credentials — run `python scripts/setup_l2.py` locally to get these
polymarket_private_key    = "0x..."
polymarket_api_key        = ""
polymarket_api_secret     = ""
polymarket_api_passphrase = ""

# Tavily search — https://tavily.com (free tier works)
tavily_api_key = "tvly-..."

# Alchemy Polygon RPC — https://alchemy.com (free tier works)
alchemy_api_key = ""
