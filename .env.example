# =============================================================================
# Penumbra — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# =============================================================================

# -----------------------------------------------------------------------------
# Polymarket CLOB API
# -----------------------------------------------------------------------------
# Public endpoints (WS + REST) work without auth.
# L2 auth is needed for /data/trades (backfill). Run: python scripts/setup_l2.py
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_REST_URL=https://clob.polymarket.com
POLYMARKET_CATEGORIES=Biotech,Politics,Crypto,Science
POLYMARKET_PRIVATE_KEY=              # Polygon wallet key (run scripts/setup_l2.py)
POLYMARKET_API_KEY=                  # Derived by setup_l2.py
POLYMARKET_API_SECRET=               # Derived by setup_l2.py
POLYMARKET_API_PASSPHRASE=           # Derived by setup_l2.py

# -----------------------------------------------------------------------------
# DuckDB (Local OLAP)
# -----------------------------------------------------------------------------
DUCKDB_PATH=data/sentinel.duckdb

# -----------------------------------------------------------------------------
# AWS Bedrock (LLM Intelligence Layer)
# -----------------------------------------------------------------------------
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_REGION=us-east-1

# Tier 1 — Quick Classifier (Nova Lite)
BEDROCK_TIER1_MODEL=amazon.nova-lite-v1:0
BEDROCK_TIER1_DAILY_LIMIT=5000

# Tier 2 — Deep Reasoner (Nova Pro — disabled by default)
BEDROCK_TIER2_MODEL=amazon.nova-pro-v1:0
BEDROCK_TIER2_DAILY_LIMIT=0
BEDROCK_TIER2_MIN_SUSPICION=60

# Judge settings
JUDGE_MAX_WORKERS=8
NEWS_CACHE_TTL_HOURS=12
NEWS_MIN_SCORE=70

# -----------------------------------------------------------------------------
# Polygon / Alchemy (On-Chain Wallet Analysis)
# -----------------------------------------------------------------------------
POLYGON_RPC_URL=https://polygon-rpc.com
ALCHEMY_API_KEY=your_alchemy_key
ALCHEMY_POLYGON_URL=https://polygon-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
FUNDING_ANOMALY_THRESHOLD_MINUTES=60

# -----------------------------------------------------------------------------
# Tavily Search (News Context for Judge)
# -----------------------------------------------------------------------------
TAVILY_API_KEY=tvly-...
EXA_API_KEY=                      # Optional fallback
NEWS_SEARCH_MAX_RESULTS=5
NEWS_SEARCH_LOOKBACK_DAYS=3

# -----------------------------------------------------------------------------
# Alerts (TODO: decide on delivery mechanism — Telegram, Slack, email, etc.)
# -----------------------------------------------------------------------------
ALERT_MIN_SCORE=80

# -----------------------------------------------------------------------------
# Scanner Thresholds
# -----------------------------------------------------------------------------
ZSCORE_THRESHOLD=3.5
MIN_TRADE_SIZE_USD=500
SIGNAL_MIN_SCORE=30
WALLET_MIN_TRADES=5
WALLET_WHITELIST_WIN_RATE=0.65
WALLET_WHITELIST_MIN_TRADES=20

# -----------------------------------------------------------------------------
# Ingester Settings
# -----------------------------------------------------------------------------
INGESTER_BATCH_SIZE=100
INGESTER_FLUSH_INTERVAL_SECONDS=5
MARKET_SYNC_INTERVAL_HOURS=6
TRADE_POLL_INTERVAL_SECONDS=30
TRADE_POLL_MAX_MARKETS=20

# -----------------------------------------------------------------------------
# FastAPI
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json
