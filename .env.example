# =============================================================================
# Penumbra — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# All values shown are the defaults from sentinel/config.py.
# Only override what you need to change.
# =============================================================================

# -----------------------------------------------------------------------------
# Polymarket CLOB API
# -----------------------------------------------------------------------------
# Public endpoints (WS + REST) work without auth.
# L2 auth is needed for /data/trades (backfill). Run: python scripts/setup_l2.py
POLYMARKET_WS_URL=wss://ws-subscriptions-clob.polymarket.com/ws/market
POLYMARKET_REST_URL=https://clob.polymarket.com
POLYMARKET_DATA_API_URL=https://data-api.polymarket.com
POLYMARKET_PRIVATE_KEY=              # Polygon wallet key (run scripts/setup_l2.py)
POLYMARKET_API_KEY=                  # Derived by setup_l2.py
POLYMARKET_API_SECRET=               # Derived by setup_l2.py
POLYMARKET_API_PASSPHRASE=           # Derived by setup_l2.py

# -----------------------------------------------------------------------------
# DuckDB (Local OLAP)
# -----------------------------------------------------------------------------
DUCKDB_PATH=data/sentinel.duckdb

# -----------------------------------------------------------------------------
# AWS Bedrock (LLM Intelligence Layer)
# -----------------------------------------------------------------------------
# Credentials are resolved via the boto3 default chain — do NOT hardcode here.
# Local dev: run `aws configure` or set AWS_PROFILE.
# CI (GitHub Actions): use aws-actions/configure-aws-credentials with OIDC.
# Production: attach an IAM role to your EC2/ECS instance.
AWS_REGION=us-east-1

# Tier 1 — Quick Classifier (Amazon Nova Lite)
BEDROCK_TIER1_MODEL=amazon.nova-lite-v1:0
BEDROCK_TIER1_DAILY_LIMIT=5000       # Judge classification budget

# Market Attractiveness Scoring — separate budget pool (also uses Nova Lite)
BEDROCK_MARKET_SCORING_DAILY_LIMIT=4000

# Tier 2 — Deep Reasoner (Amazon Nova Pro — disabled by default)
BEDROCK_TIER2_MODEL=amazon.nova-pro-v1:0
BEDROCK_TIER2_DAILY_LIMIT=0          # Set >0 to enable Tier 2 reasoning
BEDROCK_TIER2_MIN_SUSPICION=60       # Minimum T1 confidence to trigger T2

# Judge settings
JUDGE_MAX_WORKERS=8                  # Parallel Bedrock workers

# -----------------------------------------------------------------------------
# Polygon / Alchemy (On-Chain Wallet Analysis)
# -----------------------------------------------------------------------------
POLYGON_RPC_URL=https://polygon-rpc.com
ALCHEMY_API_KEY=your_alchemy_key
ALCHEMY_POLYGON_URL=https://polygon-mainnet.g.alchemy.com/v2/${ALCHEMY_API_KEY}
FUNDING_ANOMALY_THRESHOLD_MINUTES=4320   # 72 hours (tiered decay in scorer)
NEW_WALLET_LARGE_TRADE_MULTIPLIER=5.0    # trade > min_trade_size * this = suspicious

# -----------------------------------------------------------------------------
# Tavily / Exa Search (News Context for Judge)
# -----------------------------------------------------------------------------
TAVILY_API_KEY=tvly-...
EXA_API_KEY=                         # Optional fallback search provider
NEWS_SEARCH_MAX_RESULTS=5
NEWS_SEARCH_LOOKBACK_DAYS=3
NEWS_CACHE_TTL_HOURS=12              # Cache headlines to reduce API calls
NEWS_MIN_SCORE=70                    # Only fetch news for high-scoring signals

# -----------------------------------------------------------------------------
# Alerts
# -----------------------------------------------------------------------------
ALERT_MIN_SCORE=80

# -----------------------------------------------------------------------------
# Scanner Thresholds
# -----------------------------------------------------------------------------
ZSCORE_THRESHOLD=2.0                 # Modified Z-score threshold for volume anomaly
PRICE_IMPACT_FALLBACK_LIQUIDITY_USD=10000  # Fallback when Polymarket returns null
MIN_TRADE_SIZE_USD=100               # Skip trades below this size
SIGNAL_MIN_SCORE=30                  # Minimum composite score to emit signal
WALLET_MIN_TRADES=5                  # Minimum resolved trades for win-rate calc
WALLET_WHITELIST_WIN_RATE=0.65       # Win rate threshold for whitelisting
WALLET_WHITELIST_MIN_TRADES=20       # Minimum resolved trades for whitelist

# Scorer weights (must sum to 100)
SCORER_WEIGHT_VOLUME=40
SCORER_WEIGHT_IMPACT=20
SCORER_WEIGHT_WALLET=20
SCORER_WEIGHT_FUNDING=20

# -----------------------------------------------------------------------------
# Market Intelligence
# -----------------------------------------------------------------------------
HOT_MARKET_COUNT=50                  # Size of hot polling tier
HOT_MARKET_MIN_SCORE=60              # Attractiveness threshold for hot tier
HOT_MARKET_MIN_LIQUIDITY=0.0         # Polymarket returns null -> 0; formula handles it
HOT_MARKET_REFRESH_INTERVAL_SECONDS=1800  # 30 min

# -----------------------------------------------------------------------------
# Ingester Settings
# -----------------------------------------------------------------------------
INGESTER_BATCH_SIZE=20               # Trades per DB write batch
INGESTER_FLUSH_INTERVAL_SECONDS=1    # Max seconds between flushes
COORDINATION_WALLET_COUNT_MIN=3      # Min distinct wallets to flag coordination
MARKET_SYNC_INTERVAL_HOURS=2         # Full market metadata re-sync
TRADE_POLL_INTERVAL_SECONDS=5        # REST poller frequency
TRADE_POLL_LIMIT=1000                # Max trades per market per poll

# -----------------------------------------------------------------------------
# FastAPI
# -----------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000
DASHBOARD_ORIGIN=http://localhost:3000

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=json                      # "json" or "console"
